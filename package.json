    "clear-hard-source-cache": "rm -rf node_modules/.cache/hard-source/"
  },
  "dependencies": {
    "nuxt": "^2.0.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.2",
    "push-dir": "^0.4.1"
  }
}
