{
  "name": "zodiac-G12.github.io",
  "version": "1.0.0",
  "description": "My shining Nuxt.js project",
  "author": "zodiac-G12",
  "private": true,
  "scripts": {
    "dev": "nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "build:master": "DEPLOY_ENV=MASTER nuxt build",
    "generate:master": "DEPLOY_ENV=MASTER nuxt generate",
